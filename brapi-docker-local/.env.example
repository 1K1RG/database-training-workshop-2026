# Copy this file to .env and fill in your local database credentials.
# The DB_HOST default resolves to your host machine from inside Docker.

DB_HOST=host.docker.internal
DB_PORT=5432
DB_NAME=your_database_name
DB_USER=your_db_user
DB_PASSWORD=your_db_password

# Port the BrAPI server will be exposed on your host
SERVER_PORT=8080
